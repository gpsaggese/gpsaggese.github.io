    "\n",
    "# Communication metrics\n",
    "metric_names = ['Comm\\nCost', 'Comm\\nGain', 'Comm\\nEfficiency']\n",
    "metric_values = [metrics['comm_cost'], metrics['comm_gain'], metrics['comm_efficiency']]\n",
